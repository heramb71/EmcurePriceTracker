%% Auto-trade decision + confirm-fill execution flow (Supertrend strategy)
%% Render: https://mermaid.live
flowchart TD
    A["Poll (every REFRESH_SECONDS)"] --> B{"Position open?"}

    %% ── Entry path ──────────────────────────────────────────────
    B -->|No| G{"Buy gate passes?<br/>Supertrend=UP · 40&lt;RSI&lt;75<br/>vol≥0.8x · regime=Trending Up"}
    G -->|No| HOLD["Hold"]
    G -->|Yes| H{"Circuit breaker halted?<br/>2 losses / daily drawdown"}
    H -->|Yes| HOLD
    H -->|No| EV{"Within 2 days of earnings?"}
    EV -->|Yes| BLK["event_blocked alert"]
    EV -->|No| HELD{"Broker already holds shares?"}
    HELD -->|Yes| RW["reconcile_warn alert"]
    HELD -->|No| FUN{"Available funds ≥ cost?"}
    FUN -->|No| INS["insufficient_funds alert"]
    FUN -->|Yes| ORD["place_order_and_confirm(BUY)<br/>poll until COMPLETE / cancel on timeout"]
    ORD --> FZ{"Fully filled?"}
    FZ -->|No| OF["open_failed alert<br/>(NO position recorded)"]
    FZ -->|Yes| REC["Record position at REAL fill price<br/>SL=-1·ATR · T1/T2/T3=+1/2/3·ATR"]

    %% ── Manage path ─────────────────────────────────────────────
    B -->|Yes| M["manage_position()"]
    M --> SLc{"Price ≤ SL?"}
    SLc -->|Yes| XALL["Exit ALL — stop_hit"]
    SLc -->|No| STc{"Supertrend flipped down?"}
    STc -->|Yes| XST["Exit ALL — supertrend_exit"]
    STc -->|No| T3c{"Price ≥ T3 (+3·ATR)?"}
    T3c -->|Yes| S3["Sell 1/3 — t3_hit"]
    T3c -->|No| T2c{"Price ≥ T2 (+2·ATR)?"}
    T2c -->|Yes| S2["Sell 1/3 — t2_hit"]
    T2c -->|No| T1c{"Price ≥ T1 (+1·ATR)?"}
    T1c -->|Yes| S1["Sell 1/3 + move stop to breakeven — t1_hit"]
    T1c -->|No| HOLD

    %% every sell is fill-confirmed; failure keeps the position
    S3 & S2 & S1 & XALL & XST --> CONF{"Sell filled?"}
    CONF -->|No| EF["exit_failed alert<br/>(position retained — exit manually)"]
    CONF -->|Yes| DONE["Update state · net-of-charges P&L"]
