# Health endpoint API key — required to access /health (keeps trade state private)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
HEALTH_API_KEY=

# ── Telegram alerts (PRIMARY channel) ────────────────────────────────────────
# Shared bot — used by any service that doesn't set its own bot below.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Per-service Telegram bots — keep the three alert feeds separate. Any value
# left blank falls back to the shared TELEGRAM_TOKEN / TELEGRAM_CHAT_ID above,
# so you can split feeds out one bot at a time.
#   emcure  → apps/main_headless.py + apps/bot_server.py (BUY/SELL/STATUS commands)
#   radar   → apps/radar_headless.py (multi-stock opportunity scanner)
#   crypto  → apps/crypto_headless.py
TELEGRAM_EMCURE_TOKEN=
TELEGRAM_EMCURE_CHAT_ID=
TELEGRAM_RADAR_TOKEN=
TELEGRAM_RADAR_CHAT_ID=
TELEGRAM_CRYPTO_TOKEN=
TELEGRAM_CRYPTO_CHAT_ID=

# ── WhatsApp alerts via Twilio (OPT-IN fan-out) ──────────────────────────────
# Get credentials at console.twilio.com
# TWILIO_WHATSAPP_FROM: use +14155238886 for sandbox, or your approved Business number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=

# Telegram is primary. WhatsApp is OFF by default — set to 'true' to additionally
# fan every alert out to Twilio WhatsApp. Twilio's trial caps at 50 msgs/day;
# over that, WhatsApp sends silently fail. Leaving creds set with flag=false
# keeps them available for /kite_callback etc.
WHATSAPP_ENABLED=false

# Optional: override FinBERT model path (default: ProsusAI/finbert from HuggingFace)
FINBERT_MODEL_PATH=

# Supertrend Strategy — risk management
CAPITAL=500000           # Total trading capital in ₹ (default ₹5,00,000)
RISK_PCT=1.0             # Risk per trade as % of capital (default 1%)
MAX_DAILY_LOSS_PCT=3.0   # Circuit breaker: halt new entries after this daily drawdown

# ── Zerodha Kite Connect — autonomous live trading ───────────────────────────
# Get API key + secret from: https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=

# Set to 'true' to enable live order execution (default: false — alerts only)
KITE_AUTO_TRADE=false

# Optional: fully automated daily login (no manual TOKEN step needed)
# KITE_TOTP_SECRET is the base32 secret from your Zerodha 2FA setup page
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=

# Token file location (default: /opt/emcure/kite_token.json on server)
# KITE_TOKEN_FILE=/opt/emcure/kite_token.json

# Optional: run without the interactive Rich dashboard UI
HEADLESS=true

# Optional: suppress loky multiprocessing on macOS ARM (set automatically by main.py)
# LOKY_MAX_CPU_COUNT=1
# OMP_NUM_THREADS=1

# ── NSE Trade Opportunity Radar (separate emcure-radar service) ───────────────
# Multi-stock scanner: detects setups, sends Telegram alerts for MANUAL REVIEW
# ONLY (never trades), and tracks every signal's forward outcome to measure edge.
# Telegram-only — reuses TELEGRAM_TOKEN / TELEGRAM_CHAT_ID above.
RADAR_ENABLED=true            # false → service exits immediately
RADAR_REFRESH_SECONDS=300     # scan cadence during market hours
RADAR_SCORE_GATE=75           # momentum gate: alert only when confidence > this
RADAR_REVERSION_GATE=55       # lower gate for mean-reversion (high-win-rate edge)
RADAR_CORE_SYMBOLS=EMCURE     # names that bypass the ADTV gate (never silenced)
RADAR_REVERSION_STOP_ATR=0.8  # reversion stop distance in ATRs (tighter = better RR)
RADAR_MIN_RR=1.0              # floor risk:reward for reversion (caps the stop)
RADAR_MAX_ALERTS_PER_DAY=12   # daily budget; overflow collapses into a digest
RADAR_COOLDOWN_MINUTES=90     # min minutes between repeats of the same (stock,signal)
RADAR_DIGEST_MINUTES=60       # min minutes between overflow digest messages
# Liquidity floor (₹ crore). Spec default is 100, but that EXCLUDES EMCURE
# (~₹30 Cr), IREDA/IRFC (~₹90 Cr) and HUDCO (~₹42 Cr) — only ICICIBANK & SUZLON
# clear ₹100 Cr. Lower it (e.g. 25) to watch the full universe.
RADAR_MIN_ADTV_CR=100
RADAR_EOD_SUMMARY=true        # send a per-stock end-of-day summary at market close
RADAR_EOD_EXCLUDE=EMCURE      # comma-sep symbols to skip (EMCURE has its own EOD)
# RADAR_DB_PATH=/opt/emcure/radar.db   # default: repo-root radar.db
