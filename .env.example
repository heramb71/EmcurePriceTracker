# Health endpoint API key — required to access /health (keeps trade state private)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
HEALTH_API_KEY=

# Optional: Telegram alerts
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: WhatsApp alerts via Twilio
# Get credentials at console.twilio.com
# TWILIO_WHATSAPP_FROM: use +14155238886 for sandbox, or your approved Business number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=

# Optional: override FinBERT model path (default: ProsusAI/finbert from HuggingFace)
FINBERT_MODEL_PATH=

# Supertrend Strategy — risk management
CAPITAL=500000           # Total trading capital in ₹ (default ₹5,00,000)
RISK_PCT=1.0             # Risk per trade as % of capital (default 1%)
MAX_DAILY_LOSS_PCT=3.0   # Circuit breaker: halt new entries after this daily drawdown

# Optional: run without the interactive Rich dashboard UI
HEADLESS=true

# Optional: suppress loky multiprocessing on macOS ARM (set automatically by main.py)
# LOKY_MAX_CPU_COUNT=1
# OMP_NUM_THREADS=1
